# ─── LLM Provider ───────────────────────────────────────────────
OPENAI_API_KEY=sk-xxx
OPENAI_API_BASE=https://api.deepseek.com
OPENAI_MODEL=deepseek-chat

# ─── Local fine-tuned model (vLLM / Ollama) ────────────────────
LOCAL_MODEL_URL=http://localhost:8000/v1
LOCAL_MODEL_NAME=gas-expert
LOCAL_MODEL_TIMEOUT=30.0

# ─── Weather API ────────────────────────────────────────────────
# 和风天气 — 控制台「设置」查看 API Host: https://console.qweather.com/setting
WEATHER_API_HOST=https://YOUR_ID.qweatherapi.com
WEATHER_API_KEY=your_api_key

# ─── Embedding / Reranker ──────────────────────────────────────
EMBEDDING_MODEL=BAAI/bge-large-zh-v1.5
RERANKER_MODEL=BAAI/bge-reranker-v2-m3

# ─── Database ──────────────────────────────────────────────────
DATABASE_URL=sqlite+aiosqlite:///./data/copilot.db

# ─── ChromaDB ──────────────────────────────────────────────────
CHROMA_PERSIST_DIR=./data/chroma

# ─── RAG ───────────────────────────────────────────────────────
RAG_ENABLE_RERANKER=false
RAG_USE_HYDE=false

# ─── LangSmith (可观测性，可选) ────────────────────────────────
# 注册: https://smith.langchain.com  →  Settings → API Keys
LANGCHAIN_TRACING_V2=false
LANGCHAIN_API_KEY=
LANGCHAIN_PROJECT=gas-copilot

# ─── Logging ───────────────────────────────────────────────────
# LOG_FORMAT=json          # 强制 JSON 日志（Docker 中自动启用）
